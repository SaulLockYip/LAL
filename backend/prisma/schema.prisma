generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id             Int    @id @default(autoincrement())
  name           String
  nativeLanguage String
  targetLanguage String
  currentLevel   String
  voice          String?

  @@map("user")
}

model Article {
  id                   String    @id @default(uuid())
  title                String
  content              String
  source               String
  notes                String
  createdAt            DateTime  @default(now())
  archived             Boolean   @default(false)
  level                String
  currentSessionFilePath String?
  wordLists            WordList[]
  exercises            Exercise[]

  @@map("articles")
}

model WordList {
  id            Int     @id @default(autoincrement())
  articleId     String
  word          String
  partOfSpeech  String?
  phonetic      String?
  definition    String?
  translation   String?
  exampleSentence String?
  field         String?
  inflections   String?
  synonyms      String?
  phrases       String?
  derivation    String?
  etymology     String?
  article       Article? @relation(fields: [articleId], references: [id])

  @@map("word_list")
}

model Exercise {
  id              Int      @id @default(autoincrement())
  articleId       String
  type            String   // 'choice' | 'fill_blank' | 'open_ended' | 'translation' | 'word_explanation' | 'sentence_imitation'
  questionContent String   // Main question text (may contain <!--BLANK--> markers for multiple fill-in-blank)
  options         String?  // JSON array for choice questions
  correctAnswers  String?  // JSON array of correct answers (for objective questions)
  rubric          String?  // JSON object with scoring criteria
  sampleAnswer    String?  // JSON object with sample answer(s) for open-ended
  partialScoring  String?  // JSON object with partial credit information
  explanation     String?
  status          String   @default("pending")
  score           Int?     // Score as percentage (0-100) or raw points
  bandScore       Int?     // IELTS band score (0-9)
  comments        String?  // Grading feedback
  createdAt       DateTime @default(now())
  article         Article? @relation(fields: [articleId], references: [id])

  // For tracking exercise sessions (group of exercises taken together)
  sessionId       String?

  @@map("exercises")
}

model AISetting {
  id        Int    @id @default(autoincrement())
  name      String @unique
  provider  String
  modelName String
  baseUrl   String
  apiKey    String
  ttsApiKey String?

  // TTS Settings
  ttsVoiceId         String?  @default("Chinese (Mandarin)_Reliable_Executive")
  ttsSpeed           Float?   @default(1.0)
  ttsVol             Float?   @default(10.0)
  ttsPitch           Int?     @default(0)
  ttsEmotion         String?
  ttsAudioSampleRate Int?     @default(32000)
  ttsBitrate         Int?     @default(128000)
  ttsChannel         Int?     @default(1)
  ttsSoundEffects    String?

  @@map("models")
}

model TTS {
  id             String   @id @default(uuid())
  articleId      String   @unique
  audioData      String   // base64 encoded mp3
  sentenceData   String?  // JSON string of sentence timings
  createdAt      DateTime @default(now())

  @@map("tts")
}
